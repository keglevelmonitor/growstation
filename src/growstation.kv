#:kivy 2.2.0
#:import Window kivy.core.window.Window
#:import NoTransition kivy.uix.screenmanager.NoTransition

<Text_Small@Label>:
    font_size: Window.height * 0.03
    bold: True
    color: 0.7, 0.7, 0.7, 1

<Text_Medium@Label>:
    font_size: Window.height * 0.04
    bold: True
    color: 0.8, 0.8, 0.8, 1

<Text_Large@Label>:
    font_size: Window.height * 0.05
    bold: True
    color: app.col_theme_blue

<ScaledButton@Button>:
    font_size: Window.height * 0.04
    bold: True
    background_normal: ''
    background_color: 0.4, 0.4, 0.4, 1

<ScaledSmallButton@Button>:
    font_size: Window.height * 0.03
    bold: True

<ScaledSmallSpinner@Spinner>:
    font_size: Window.height * 0.03
    bold: True

<ScaledSmallTextInput@TextInput>:
    font_size: Window.height * 0.03
    bold: True
    background_color: 0.4, 0.4, 0.4, 1
    foreground_color: 1, 1, 1, 1
    multiline: False

<SettingRow@BoxLayout>:
    orientation: 'horizontal'
    spacing: 10
    size_hint_y: None
    height: Window.height * 0.08
    padding: [10, 5]

<SettingLabel@Label>:
    text_size: self.size
    halign: 'right'
    valign: 'middle'
    size_hint_x: 0.4
    color: 0.7, 0.7, 0.7, 1
    font_size: Window.height * 0.03
    bold: True

<TabButton@ToggleButton>:
    group: 'settings_tabs'
    font_size: '16sp'
    bold: True
    background_normal: ''
    background_color: (0.2, 0.2, 0.2, 1) if self.state == 'normal' else (1, 0.75, 0, 1)
    color: (1, 1, 1, 1) if self.state == 'normal' else (0, 0, 0, 1)
    allow_no_selection: False
    disabled: app.is_settings_dirty and self.state == 'normal'
    opacity: 0.4 if app.is_settings_dirty and self.state == 'normal' else 1.0

<StandardSettingsFooter@GridLayout>:
    cols: 5
    size_hint_y: 0.12
    spacing: 5
    ScaledButton:
        text: "EXIT"
        on_release: app.attempt_exit_settings()
    ScaledButton:
        text: "HELP"
    Label:
        text: ""
    ScaledButton:
        text: "RESET/DEFAULTS"
        on_release: app.reset_defaults()
    ScaledButton:
        text: "SAVE"
        background_color: 0.2, 0.8, 0.2, 1
        on_release: app.save_current_tab()

<UpdatesFooter@GridLayout>:
    cols: 5
    size_hint_y: 0.12
    spacing: 5
    ScaledButton:
        text: "EXIT"
        on_release: app.attempt_exit_settings()
    ScaledButton:
        text: "HELP"
    ScaledButton:
        text: "CHECK"
        background_color: 0.2, 0.6, 0.8, 1
        on_release: app.check_for_updates()
    ScaledButton:
        text: "INSTALL"
        disabled: not app.is_update_available
        background_disabled_normal: ''
        background_disabled_down: ''
        background_color: (0.2, 0.8, 0.2, 1) if app.is_update_available else (0.3, 0.3, 0.3, 1)
        on_release: app.run_update_script()
    ScaledButton:
        text: "RESTART APP"
        disabled: not app.is_install_successful
        background_disabled_normal: ''
        background_disabled_down: ''
        background_color: (1, 0.6, 0, 1) if app.is_install_successful else (0.3, 0.3, 0.3, 1)
        on_release: app.restart_application()

<AboutFooter@GridLayout>:
    cols: 5
    size_hint_y: 0.12
    spacing: 5
    ScaledButton:
        text: "EXIT"
        on_release: app.attempt_exit_settings()
    ScaledButton:
        text: "HELP"
    Label:
        text: ""
    Label:
        text: ""
    Label:
        text: ""

<DirtyPopup@Popup>:
    title: 'Unsaved Changes'
    size_hint: 0.8, 0.4
    auto_dismiss: False
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 10
        Text_Medium:
            text: "You have unsaved changes.\nDo you want to save them before exiting?"
            halign: 'center'
        BoxLayout:
            spacing: 10
            size_hint_y: None
            height: 50
            ScaledButton:
                text: "DISCARD & CONTINUE"
                background_color: 0.8, 0.2, 0.2, 1
                on_release:
                    app.discard_changes()
                    root.dismiss()
            ScaledButton:
                text: "CANCEL"
                on_release: root.dismiss()
            ScaledButton:
                text: "SAVE & CONTINUE"
                background_color: 0.2, 0.8, 0.2, 1
                on_release:
                    app.save_and_continue()
                    root.dismiss()

# --- DASHBOARD ---
<DashboardScreen>:
    name: 'dashboard'
    BoxLayout:
        orientation: 'vertical'
        padding: Window.height * 0.01
        spacing: Window.height * 0.01
        canvas.before:
            Color:
                rgba: 0.1, 0.1, 0.1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: Window.height * 0.06
            Text_Large:
                text: "GrowStation"
                color: 1, 0.6, 0, 1
                size_hint_x: 0.5

        GridLayout:
            cols: 3
            size_hint_y: 0.5
            spacing: Window.height * 0.02
            padding: [0, 5]

            BoxLayout:
                orientation: 'vertical'
                spacing: 3
                canvas.before:
                    Color:
                        rgba: 0.2, 0.2, 0.2, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                padding: [8, 8]
                Text_Medium:
                    text: "RELAY 1"
                    color: 0.7, 0.7, 0.7, 1
                    size_hint_y: None
                    height: Window.height * 0.06
                Text_Medium:
                    text: app.relay_labels[0] if len(app.relay_labels) > 0 else "Relay 1"
                    font_size: Window.height * 0.035
                    color: app.col_theme_blue
                    size_hint_y: None
                    height: Window.height * 0.055
                Button:
                    text: "ON" if (app.relay_states[0] if len(app.relay_states) > 0 else False) else "OFF"
                    font_size: Window.height * 0.055
                    bold: True
                    background_normal: ''
                    background_color: (0.15, 0.75, 0.15, 1) if (app.relay_states[0] if len(app.relay_states) > 0 else False) else (0.38, 0.38, 0.38, 1)
                Label:
                    text: ("NEXT SCHED: " + app.relay_next_action_0 + " at " + app.relay_next_time_0) if app.relay_next_action_0 != '--' else "NEXT SCHED: --"
                    font_size: Window.height * 0.04
                    bold: True
                    color: (0.2, 1, 0.2, 1) if app.relay_next_action_0 == 'ON' else ((1, 0.45, 0.45, 1) if app.relay_next_action_0 == 'OFF' else (0.5, 0.5, 0.5, 1))
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_y: None
                    height: Window.height * 0.08
                BoxLayout:
                    size_hint_y: None
                    height: Window.height * 0.09
                    spacing: 3
                    Button:
                        text: "SCHED"
                        font_size: Window.height * 0.04
                        bold: True
                        background_normal: ''
                        background_color: (0.1, 0.65, 0.1, 1) if app.relay_op_mode_0 == 'schedule' else (0.28, 0.28, 0.28, 1)
                        on_release: app.set_relay_op_mode(0, 'schedule')
                    Button:
                        text: "SKIP"
                        font_size: Window.height * 0.04
                        bold: True
                        background_normal: ''
                        background_color: (0.85, 0.5, 0.0, 1) if app.relay_op_mode_0 == 'skip' else (0.28, 0.28, 0.28, 1)
                        on_release: app.set_relay_op_mode(0, 'skip')
                    Button:
                        text: "MAN"
                        font_size: Window.height * 0.04
                        bold: True
                        background_normal: ''
                        background_color: (0.2, 0.4, 0.85, 1) if app.relay_op_mode_0 == 'manual' else (0.28, 0.28, 0.28, 1)
                        on_release: app.set_relay_op_mode(0, 'manual')

            BoxLayout:
                orientation: 'vertical'
                spacing: 3
                canvas.before:
                    Color:
                        rgba: 0.2, 0.2, 0.2, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                padding: [8, 8]
                Text_Medium:
                    text: "RELAY 2"
                    color: 0.7, 0.7, 0.7, 1
                    size_hint_y: None
                    height: Window.height * 0.06
                Text_Medium:
                    text: app.relay_labels[1] if len(app.relay_labels) > 1 else "Relay 2"
                    font_size: Window.height * 0.035
                    color: app.col_theme_blue
                    size_hint_y: None
                    height: Window.height * 0.055
                Button:
                    text: "ON" if (app.relay_states[1] if len(app.relay_states) > 1 else False) else "OFF"
                    font_size: Window.height * 0.055
                    bold: True
                    background_normal: ''
                    background_color: (0.15, 0.75, 0.15, 1) if (app.relay_states[1] if len(app.relay_states) > 1 else False) else (0.38, 0.38, 0.38, 1)
                Label:
                    text: ("NEXT SCHED: " + app.relay_next_action_1 + " at " + app.relay_next_time_1) if app.relay_next_action_1 != '--' else "NEXT SCHED: --"
                    font_size: Window.height * 0.04
                    bold: True
                    color: (0.2, 1, 0.2, 1) if app.relay_next_action_1 == 'ON' else ((1, 0.45, 0.45, 1) if app.relay_next_action_1 == 'OFF' else (0.5, 0.5, 0.5, 1))
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_y: None
                    height: Window.height * 0.08
                BoxLayout:
                    size_hint_y: None
                    height: Window.height * 0.09
                    spacing: 3
                    Button:
                        text: "SCHED"
                        font_size: Window.height * 0.04
                        bold: True
                        background_normal: ''
                        background_color: (0.1, 0.65, 0.1, 1) if app.relay_op_mode_1 == 'schedule' else (0.28, 0.28, 0.28, 1)
                        on_release: app.set_relay_op_mode(1, 'schedule')
                    Button:
                        text: "SKIP"
                        font_size: Window.height * 0.04
                        bold: True
                        background_normal: ''
                        background_color: (0.85, 0.5, 0.0, 1) if app.relay_op_mode_1 == 'skip' else (0.28, 0.28, 0.28, 1)
                        on_release: app.set_relay_op_mode(1, 'skip')
                    Button:
                        text: "MAN"
                        font_size: Window.height * 0.04
                        bold: True
                        background_normal: ''
                        background_color: (0.2, 0.4, 0.85, 1) if app.relay_op_mode_1 == 'manual' else (0.28, 0.28, 0.28, 1)
                        on_release: app.set_relay_op_mode(1, 'manual')

            BoxLayout:
                orientation: 'vertical'
                spacing: 3
                canvas.before:
                    Color:
                        rgba: 0.2, 0.2, 0.2, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                padding: [8, 8]
                Text_Medium:
                    text: "RELAY 3"
                    color: 0.7, 0.7, 0.7, 1
                    size_hint_y: None
                    height: Window.height * 0.06
                Text_Medium:
                    text: app.relay_labels[2] if len(app.relay_labels) > 2 else "Relay 3"
                    font_size: Window.height * 0.035
                    color: app.col_theme_blue
                    size_hint_y: None
                    height: Window.height * 0.055
                Button:
                    text: "ON" if (app.relay_states[2] if len(app.relay_states) > 2 else False) else "OFF"
                    font_size: Window.height * 0.055
                    bold: True
                    background_normal: ''
                    background_color: (0.15, 0.75, 0.15, 1) if (app.relay_states[2] if len(app.relay_states) > 2 else False) else (0.38, 0.38, 0.38, 1)
                Label:
                    text: ("NEXT SCHED: " + app.relay_next_action_2 + " at " + app.relay_next_time_2) if app.relay_next_action_2 != '--' else "NEXT SCHED: --"
                    font_size: Window.height * 0.04
                    bold: True
                    color: (0.2, 1, 0.2, 1) if app.relay_next_action_2 == 'ON' else ((1, 0.45, 0.45, 1) if app.relay_next_action_2 == 'OFF' else (0.5, 0.5, 0.5, 1))
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_y: None
                    height: Window.height * 0.08
                BoxLayout:
                    size_hint_y: None
                    height: Window.height * 0.09
                    spacing: 3
                    Button:
                        text: "SCHED"
                        font_size: Window.height * 0.04
                        bold: True
                        background_normal: ''
                        background_color: (0.1, 0.65, 0.1, 1) if app.relay_op_mode_2 == 'schedule' else (0.28, 0.28, 0.28, 1)
                        on_release: app.set_relay_op_mode(2, 'schedule')
                    Button:
                        text: "SKIP"
                        font_size: Window.height * 0.04
                        bold: True
                        background_normal: ''
                        background_color: (0.85, 0.5, 0.0, 1) if app.relay_op_mode_2 == 'skip' else (0.28, 0.28, 0.28, 1)
                        on_release: app.set_relay_op_mode(2, 'skip')
                    Button:
                        text: "MAN"
                        font_size: Window.height * 0.04
                        bold: True
                        background_normal: ''
                        background_color: (0.2, 0.4, 0.85, 1) if app.relay_op_mode_2 == 'manual' else (0.28, 0.28, 0.28, 1)
                        on_release: app.set_relay_op_mode(2, 'manual')

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 0.15
            spacing: 20
            padding: [10, 5]
            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            Text_Medium:
                text: app.temp_name_1 + ": " + app.temp_1 + ("°F" if app.temp_units == "F" else "°C")
                size_hint_x: 0.33
            Text_Medium:
                text: app.temp_name_2 + ": " + app.temp_2 + ("°F" if app.temp_units == "F" else "°C")
                size_hint_x: 0.33
            Text_Medium:
                text: app.temp_name_3 + ": " + app.temp_3 + ("°F" if app.temp_units == "F" else "°C")
                size_hint_x: 0.33

        BoxLayout:
            size_hint_y: 0.12
            spacing: 10
            ScaledButton:
                text: "SYSTEM LOG"
                on_release: app.go_to_screen('log')
            ScaledButton:
                text: "SETTINGS"
                on_release: app.go_to_screen('settings')
            ScaledButton:
                text: "HELP"

# --- LOG SCREEN ---
<LogScreen>:
    name: 'log'
    BoxLayout:
        orientation: 'vertical'
        padding: 5
        spacing: 5
        BoxLayout:
            size_hint_y: None
            height: Window.height * 0.08
            Text_Large:
                text: "SYSTEM LOG"
                size_hint_x: 0.5
            BoxLayout:
                size_hint_x: 0.5
                spacing: 5
                CheckBox:
                    active: app.system_logging_enabled
                    on_active: app.stage_setting('system_logging_enabled', self.active); app.system_logging_enabled = self.active
                Text_Small:
                    text: "Append to growstation-data/system_log.csv"
        ScrollView:
            do_scroll_x: False
            bar_width: 15
            bar_color: 0.2, 0.8, 1, 1
            Label:
                text: app.log_text
                font_size: Window.height * 0.035
                color: 0.8, 0.8, 0.8, 1
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width - 20, None
                halign: 'left'
                valign: 'top'
                padding: [10, 10]
        BoxLayout:
            size_hint_y: 0.12
            ScaledButton:
                text: "EXIT"
                on_release: app.go_to_screen('dashboard')
            ScaledButton:
                text: "HELP"

# --- SETTINGS SCREEN ---
# KegLevel Lite pattern: TabButtons + dual ScreenManager (content + footer) = single footer row, consistent layout
<SettingsScreen>:
    name: 'settings'
    on_enter: app.scan_sensors()
    on_pre_enter: root.set_active_tab('schedules')
    BoxLayout:
        orientation: 'vertical'
        padding: [10, 5]
        spacing: 5

        # --- TAB HEADER ---
        BoxLayout:
            size_hint_y: None
            height: Window.height * 0.08
            padding: 5
            spacing: 2
            TabButton:
                id: btn_schedules
                text: "SCHEDULES"
                on_release: root.set_active_tab('schedules')
            TabButton:
                id: btn_relays
                text: "RELAYS"
                on_release: root.set_active_tab('relays')
            TabButton:
                id: btn_sensors
                text: "SENSORS"
                on_release: root.set_active_tab('sensors')
            TabButton:
                id: btn_system
                text: "SYSTEM"
                on_release: root.set_active_tab('system')
            TabButton:
                id: btn_updates
                text: "UPDATES"
                on_release: root.set_active_tab('updates')
            TabButton:
                id: btn_about
                text: "ABOUT"
                on_release: root.set_active_tab('about')

        # --- CONTENT AREA ---
        ScreenManager:
            id: settings_content
            transition: NoTransition()
            Screen:
                name: 'tab_schedules'
                canvas.before:
                    Color:
                        rgba: 0.1, 0.1, 0.1, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                BoxLayout:
                    orientation: 'vertical'
                    padding: [8, 8]
                    spacing: 4

                    # Header row
                    BoxLayout:
                        size_hint_y: None
                        height: Window.height * 0.09
                        Label:
                            text: ""
                            size_hint_x: None
                            width: 70
                        Text_Medium:
                            text: app.relay_labels[0]
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size
                        Text_Medium:
                            text: app.relay_labels[1]
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size
                        Text_Medium:
                            text: app.relay_labels[2]
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size

                    # ON row
                    BoxLayout:
                        size_hint_y: None
                        height: Window.height * 0.22
                        SettingLabel:
                            text: "ON"
                            size_hint_x: None
                            width: 70
                            font_size: Window.height * 0.04
                        BoxLayout:
                            orientation: 'vertical'
                            padding: [5, 0]
                            Slider:
                                min: 0
                                max: 47
                                step: 1
                                value: app.sched_on_0
                                value_track: True
                                value_track_color: 0.2, 0.8, 1, 1
                                on_value: app.set_sched_on(0, int(self.value))
                            Label:
                                text: "ALWAYS ON" if (app.sched_on_0 == 47 and app.sched_off_0 == 47) else app.slot_to_time(app.sched_on_0)
                                font_size: Window.height * 0.038
                                bold: True
                                color: (0.2, 1, 0.2, 1) if (app.sched_on_0 == 47 and app.sched_off_0 == 47) else ((1, 0.75, 0, 1) if app.sched_on_0 > 0 else (0.5, 0.5, 0.5, 1))
                                halign: 'center'
                                text_size: self.size
                                valign: 'middle'
                        BoxLayout:
                            orientation: 'vertical'
                            padding: [5, 0]
                            Slider:
                                min: 0
                                max: 47
                                step: 1
                                value: app.sched_on_1
                                value_track: True
                                value_track_color: 0.2, 0.8, 1, 1
                                on_value: app.set_sched_on(1, int(self.value))
                            Label:
                                text: "ALWAYS ON" if (app.sched_on_1 == 47 and app.sched_off_1 == 47) else app.slot_to_time(app.sched_on_1)
                                font_size: Window.height * 0.038
                                bold: True
                                color: (0.2, 1, 0.2, 1) if (app.sched_on_1 == 47 and app.sched_off_1 == 47) else ((1, 0.75, 0, 1) if app.sched_on_1 > 0 else (0.5, 0.5, 0.5, 1))
                                halign: 'center'
                                text_size: self.size
                                valign: 'middle'
                        BoxLayout:
                            orientation: 'vertical'
                            padding: [5, 0]
                            Slider:
                                min: 0
                                max: 47
                                step: 1
                                value: app.sched_on_2
                                value_track: True
                                value_track_color: 0.2, 0.8, 1, 1
                                on_value: app.set_sched_on(2, int(self.value))
                            Label:
                                text: "ALWAYS ON" if (app.sched_on_2 == 47 and app.sched_off_2 == 47) else app.slot_to_time(app.sched_on_2)
                                font_size: Window.height * 0.038
                                bold: True
                                color: (0.2, 1, 0.2, 1) if (app.sched_on_2 == 47 and app.sched_off_2 == 47) else ((1, 0.75, 0, 1) if app.sched_on_2 > 0 else (0.5, 0.5, 0.5, 1))
                                halign: 'center'
                                text_size: self.size
                                valign: 'middle'

                    # OFF row
                    BoxLayout:
                        size_hint_y: None
                        height: Window.height * 0.22
                        SettingLabel:
                            text: "OFF"
                            size_hint_x: None
                            width: 70
                            font_size: Window.height * 0.04
                        BoxLayout:
                            orientation: 'vertical'
                            padding: [5, 0]
                            Slider:
                                min: 0
                                max: 47
                                step: 1
                                value: app.sched_off_0
                                value_track: True
                                value_track_color: 0.8, 0.3, 0.3, 1
                                on_value: app.set_sched_off(0, int(self.value))
                            Label:
                                text: "ALWAYS ON" if (app.sched_on_0 == 47 and app.sched_off_0 == 47) else app.slot_to_time(app.sched_off_0)
                                font_size: Window.height * 0.038
                                bold: True
                                color: (0.2, 1, 0.2, 1) if (app.sched_on_0 == 47 and app.sched_off_0 == 47) else ((1, 0.75, 0, 1) if app.sched_off_0 > 0 else (0.5, 0.5, 0.5, 1))
                                halign: 'center'
                                text_size: self.size
                                valign: 'middle'
                        BoxLayout:
                            orientation: 'vertical'
                            padding: [5, 0]
                            Slider:
                                min: 0
                                max: 47
                                step: 1
                                value: app.sched_off_1
                                value_track: True
                                value_track_color: 0.8, 0.3, 0.3, 1
                                on_value: app.set_sched_off(1, int(self.value))
                            Label:
                                text: "ALWAYS ON" if (app.sched_on_1 == 47 and app.sched_off_1 == 47) else app.slot_to_time(app.sched_off_1)
                                font_size: Window.height * 0.038
                                bold: True
                                color: (0.2, 1, 0.2, 1) if (app.sched_on_1 == 47 and app.sched_off_1 == 47) else ((1, 0.75, 0, 1) if app.sched_off_1 > 0 else (0.5, 0.5, 0.5, 1))
                                halign: 'center'
                                text_size: self.size
                                valign: 'middle'
                        BoxLayout:
                            orientation: 'vertical'
                            padding: [5, 0]
                            Slider:
                                min: 0
                                max: 47
                                step: 1
                                value: app.sched_off_2
                                value_track: True
                                value_track_color: 0.8, 0.3, 0.3, 1
                                on_value: app.set_sched_off(2, int(self.value))
                            Label:
                                text: "ALWAYS ON" if (app.sched_on_2 == 47 and app.sched_off_2 == 47) else app.slot_to_time(app.sched_off_2)
                                font_size: Window.height * 0.038
                                bold: True
                                color: (0.2, 1, 0.2, 1) if (app.sched_on_2 == 47 and app.sched_off_2 == 47) else ((1, 0.75, 0, 1) if app.sched_off_2 > 0 else (0.5, 0.5, 0.5, 1))
                                halign: 'center'
                                text_size: self.size
                                valign: 'middle'

                    Widget:
                        size_hint_y: 1
            Screen:
                name: 'tab_relays'
                canvas.before:
                    Color:
                        rgba: 0.1, 0.1, 0.1, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                ScrollView:
                    do_scroll_x: False
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        padding: [5, 10]
                        GridLayout:
                            cols: 4
                            spacing: 10
                            size_hint_y: None
                            height: self.minimum_height
                            row_default_height: Window.height * 0.08
                            Label:
                                text: ""
                                size_hint_x: None
                                width: 100
                            Text_Medium:
                                text: "Relay 1"
                                halign: 'center'
                                text_size: self.size
                            Text_Medium:
                                text: "Relay 2"
                                halign: 'center'
                                text_size: self.size
                            Text_Medium:
                                text: "Relay 3"
                                halign: 'center'
                                text_size: self.size
                            SettingLabel:
                                text: "Label"
                                size_hint_x: None
                                width: 100
                            ScaledSmallTextInput:
                                text: app.relay_labels[0]
                                on_text: app.stage_setting('relay_0_label', self.text); app.relay_labels[0] = self.text
                            ScaledSmallTextInput:
                                text: app.relay_labels[1]
                                on_text: app.stage_setting('relay_1_label', self.text); app.relay_labels[1] = self.text
                            ScaledSmallTextInput:
                                text: app.relay_labels[2]
                                on_text: app.stage_setting('relay_2_label', self.text); app.relay_labels[2] = self.text
                            SettingLabel:
                                text: "Control Mode"
                                size_hint_x: None
                                width: 100
                            ScaledSmallSpinner:
                                id: relay0_mode
                                text: app.relay_control_mode_0
                                values: ["Timer only", "Thermostatic only", "Both"]
                                on_text: app.stage_setting('relay_0_control_mode', self.text); setattr(app, 'relay_control_mode_0', self.text)
                            ScaledSmallSpinner:
                                id: relay1_mode
                                text: app.relay_control_mode_1
                                values: ["Timer only", "Thermostatic only", "Both"]
                                on_text: app.stage_setting('relay_1_control_mode', self.text); setattr(app, 'relay_control_mode_1', self.text)
                            ScaledSmallSpinner:
                                id: relay2_mode
                                text: app.relay_control_mode_2
                                values: ["Timer only", "Thermostatic only", "Both"]
                                on_text: app.stage_setting('relay_2_control_mode', self.text); setattr(app, 'relay_control_mode_2', self.text)
            Screen:
                name: 'tab_sensors'
                canvas.before:
                    Color:
                        rgba: 0.1, 0.1, 0.1, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                ScrollView:
                    do_scroll_x: False
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        padding: [5, 10]
                        ScaledButton:
                            text: "Scan Sensors"
                            size_hint_y: None
                            height: 40
                            on_release: app.scan_sensors()
                        GridLayout:
                            cols: 4
                            spacing: 10
                            size_hint_y: None
                            height: self.minimum_height
                            row_default_height: Window.height * 0.08
                            Label:
                                text: ""
                                size_hint_x: None
                                width: 100
                            Text_Medium:
                                text: "Sensor 1"
                                halign: 'center'
                                text_size: self.size
                            Text_Medium:
                                text: "Sensor 2"
                                halign: 'center'
                                text_size: self.size
                            Text_Medium:
                                text: "Sensor 3"
                                halign: 'center'
                                text_size: self.size
                            SettingLabel:
                                text: "ID"
                                size_hint_x: None
                                width: 100
                            ScaledSmallSpinner:
                                id: sensor_id_spinner_1
                                text: app.sensor_id_1
                                values: app.available_sensors
                                on_text: app.stage_setting('sensor_0_ds18b20_id', self.text); setattr(app, 'sensor_id_1', self.text)
                            ScaledSmallSpinner:
                                id: sensor_id_spinner_2
                                text: app.sensor_id_2
                                values: app.available_sensors
                                on_text: app.stage_setting('sensor_1_ds18b20_id', self.text); setattr(app, 'sensor_id_2', self.text)
                            ScaledSmallSpinner:
                                id: sensor_id_spinner_3
                                text: app.sensor_id_3
                                values: app.available_sensors
                                on_text: app.stage_setting('sensor_2_ds18b20_id', self.text); setattr(app, 'sensor_id_3', self.text)
                            SettingLabel:
                                text: "Name"
                                size_hint_x: None
                                width: 100
                            ScaledSmallTextInput:
                                text: app.temp_name_1
                                on_text: app.stage_setting('sensor_0_display_name', self.text); setattr(app, 'temp_name_1', self.text)
                            ScaledSmallTextInput:
                                text: app.temp_name_2
                                on_text: app.stage_setting('sensor_1_display_name', self.text); setattr(app, 'temp_name_2', self.text)
                            ScaledSmallTextInput:
                                text: app.temp_name_3
                                on_text: app.stage_setting('sensor_2_display_name', self.text); setattr(app, 'temp_name_3', self.text)
            Screen:
                name: 'tab_system'
                canvas.before:
                    Color:
                        rgba: 0.1, 0.1, 0.1, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                ScrollView:
                    do_scroll_x: False
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        padding: [5, 10]
                        SettingRow:
                            SettingLabel:
                                text: "Temperature Units"
                            BoxLayout:
                                spacing: 10
                                ToggleButton:
                                    text: "Fahrenheit"
                                    group: "units"
                                    state: 'down' if app.temp_units == 'F' else 'normal'
                                    on_release: app.stage_setting('temp_units', 'F'); app.temp_units = 'F'
                                ToggleButton:
                                    text: "Celsius"
                                    group: "units"
                                    state: 'down' if app.temp_units == 'C' else 'normal'
                                    on_release: app.stage_setting('temp_units', 'C'); app.temp_units = 'C'
                        SettingRow:
                            SettingLabel:
                                text: "Relay Logic"
                            BoxLayout:
                                spacing: 10
                                ToggleButton:
                                    text: "Active HIGH"
                                    group: "relay_logic"
                                    state: 'down' if app.relay_active_high else 'normal'
                                    on_release: app.stage_setting('relay_active_high', True); app.relay_active_high = True
                                ToggleButton:
                                    text: "Active LOW"
                                    group: "relay_logic"
                                    state: 'down' if not app.relay_active_high else 'normal'
                                    on_release: app.stage_setting('relay_active_high', False); app.relay_active_high = False
                        SettingRow:
                            SettingLabel:
                                text: "Log Interval (min)"
                            ScaledSmallTextInput:
                                text: app.logging_interval_min
                                on_text: app.stage_setting('logging_interval_min', self.text); app.logging_interval_min = self.text
                        SettingRow:
                            SettingLabel:
                                text: "Detailed Log"
                            CheckBox:
                                active: app.system_logging_enabled
                                on_active: app.stage_setting('system_logging_enabled', self.active); app.system_logging_enabled = self.active
            Screen:
                name: 'tab_updates'
                canvas.before:
                    Color:
                        rgba: 0.1, 0.1, 0.1, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                BoxLayout:
                    orientation: 'vertical'
                    padding: [5, 10]
                    Text_Medium:
                        text: "Software Update Log"
                        size_hint_y: None
                        height: Window.height * 0.07
                        color: 0.7, 0.7, 0.7, 1
                    TextInput:
                        text: app.update_log_text
                        readonly: True
                        font_size: Window.height * 0.03
                        background_color: 0.15, 0.15, 0.15, 1
                        foreground_color: 0.9, 0.9, 0.9, 1
            Screen:
                name: 'tab_about'
                canvas.before:
                    Color:
                        rgba: 0.1, 0.1, 0.1, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                BoxLayout:
                    orientation: 'horizontal'
                    padding: [10, 10]
                    spacing: 10
                    size_hint_y: 1
                    ScrollView:
                        do_scroll_x: False
                        size_hint_x: 0.75
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: 10
                            Text_Large:
                                text: "KegLevel Brands"
                                color: 1, 0.6, 0, 1
                                size_hint_y: None
                                height: Window.height * 0.05
                                halign: 'left'
                                text_size: self.size
                            Text_Medium:
                                text: "Keglevel Lite(c), KegLevel Monitor(c), KettleBrain(c), and FermVault(c) names, texts, UI/UX and program code are copyrighted. This material and all components of this program are protected by copyright law. Unauthorized use, duplication, or distribution is strictly prohibited."
                                bold: False
                                size_hint_y: None
                                height: self.texture_size[1]
                                text_size: self.width, None
                                halign: 'left'
                                color: 0.8, 0.8, 0.8, 1
                            Widget:
                                size_hint_y: None
                                height: 20
                            Text_Large:
                                text: "Support This App"
                                color: 1, 0.6, 0, 1
                                size_hint_y: None
                                height: Window.height * 0.05
                                halign: 'left'
                                text_size: self.size
                            Text_Medium:
                                text: "This App took hundreds of hours to develop, test, and optimize. Please consider supporting this App with a donation so continuous improvements can be made. If you wish to receive customer support via email, please make a reasonable donation. Customer support requests without a donation may not be considered."
                                bold: False
                                size_hint_y: None
                                height: self.texture_size[1]
                                text_size: self.width, None
                                halign: 'left'
                                color: 0.8, 0.8, 0.8, 1
                            Widget:
                                size_hint_y: None
                                height: 20
                            Text_Large:
                                text: "Acknowledgements"
                                color: 1, 0.6, 0, 1
                                size_hint_y: None
                                height: Window.height * 0.05
                                halign: 'left'
                                text_size: self.size
                            Text_Medium:
                                text: "Icons created by Pixel Perfect - Flaticon\nhttps://www.flaticon.com/free-icons/update"
                                bold: False
                                size_hint_y: None
                                height: self.texture_size[1]
                                text_size: self.width, None
                                halign: 'left'
                                color: 0.8, 0.8, 0.8, 1
                    AnchorLayout:
                        anchor_x: 'right'
                        anchor_y: 'top'
                        size_hint_x: None
                        width: 200
                        size_hint_y: 1
                        padding: [0, 20, 20, 0]
                        Image:
                            source: 'assets/support.gif'
                            size_hint: None, None
                            size: 140, 140
                            fit_mode: 'contain'

        # --- FOOTER (single row, KegLevel-style inline buttons) ---
        ScreenManager:
            id: settings_footer
            size_hint_y: None
            height: 60
            transition: NoTransition()
            Screen:
                name: 'footer_schedules'
                BoxLayout:
                    padding: 5
                    spacing: 10
                    ScaledButton:
                        text: "EXIT"
                        on_release: app.attempt_exit_settings()
                    ScaledButton:
                        text: "HELP"
                    Label:
                        text: ""
                    ScaledButton:
                        text: "RESET/DEFAULTS"
                        on_release: app.reset_defaults()
                    ScaledButton:
                        text: "SAVE"
                        background_color: 0.2, 0.8, 0.2, 1
                        on_release: app.save_current_tab()
            Screen:
                name: 'footer_relays'
                BoxLayout:
                    padding: 5
                    spacing: 10
                    ScaledButton:
                        text: "EXIT"
                        on_release: app.attempt_exit_settings()
                    ScaledButton:
                        text: "HELP"
                    Label:
                        text: ""
                    ScaledButton:
                        text: "RESET/DEFAULTS"
                        on_release: app.reset_defaults()
                    ScaledButton:
                        text: "SAVE"
                        background_color: 0.2, 0.8, 0.2, 1
                        on_release: app.save_current_tab()
            Screen:
                name: 'footer_sensors'
                BoxLayout:
                    padding: 5
                    spacing: 10
                    ScaledButton:
                        text: "EXIT"
                        on_release: app.attempt_exit_settings()
                    ScaledButton:
                        text: "HELP"
                    Label:
                        text: ""
                    ScaledButton:
                        text: "RESET/DEFAULTS"
                        on_release: app.reset_defaults()
                    ScaledButton:
                        text: "SAVE"
                        background_color: 0.2, 0.8, 0.2, 1
                        on_release: app.save_current_tab()
            Screen:
                name: 'footer_system'
                BoxLayout:
                    padding: 5
                    spacing: 10
                    ScaledButton:
                        text: "EXIT"
                        on_release: app.attempt_exit_settings()
                    ScaledButton:
                        text: "HELP"
                    Label:
                        text: ""
                    ScaledButton:
                        text: "RESET/DEFAULTS"
                        on_release: app.reset_defaults()
                    ScaledButton:
                        text: "SAVE"
                        background_color: 0.2, 0.8, 0.2, 1
                        on_release: app.save_current_tab()
            Screen:
                name: 'footer_updates'
                BoxLayout:
                    padding: 5
                    spacing: 10
                    ScaledButton:
                        text: "EXIT"
                        on_release: app.attempt_exit_settings()
                    ScaledButton:
                        text: "HELP"
                    ScaledButton:
                        text: "CHECK"
                        background_color: 0.2, 0.6, 0.8, 1
                        on_release: app.check_for_updates()
                    ScaledButton:
                        text: "INSTALL"
                        disabled: not app.is_update_available
                        background_disabled_normal: ''
                        background_disabled_down: ''
                        background_color: (0.2, 0.8, 0.2, 1) if app.is_update_available else (0.3, 0.3, 0.3, 1)
                        on_release: app.run_update_script()
                    ScaledButton:
                        text: "RESTART APP"
                        disabled: not app.is_install_successful
                        background_disabled_normal: ''
                        background_disabled_down: ''
                        background_color: (1, 0.6, 0, 1) if app.is_install_successful else (0.3, 0.3, 0.3, 1)
                        on_release: app.restart_application()
            Screen:
                name: 'footer_about'
                BoxLayout:
                    padding: 5
                    spacing: 10
                    ScaledButton:
                        text: "EXIT"
                        on_release: app.attempt_exit_settings()
                    ScaledButton:
                        text: "HELP"
                    Label:
                        text: ""
                    Label:
                        text: ""
                    Label:
                        text: ""

# --- ROOT ---
ScreenManager:
    id: screen_manager
    DashboardScreen:
        id: dashboard
    LogScreen:
        id: log
    SettingsScreen:
        id: settings
